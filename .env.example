# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # solo servidor, NUNCA exponer al cliente

# Resend
RESEND_API_KEY=re_xxxxxxxxxxxx

# TheSportsDB (fixtures del Mundial). "3" es el key de prueba gratis (limitado).
# Para el fixture completo usar un key premium.
THESPORTSDB_KEY=3

# Cron (string aleatorio >= 16 chars para proteger endpoints de cron)
CRON_SECRET=change-me-to-a-random-string

# URL pública de la app (usada por GitHub Actions para llamar a los endpoints de cron)
APP_URL=http://localhost:3000

# Email del único admin de la app (acceso al panel /admin)
ADMIN_EMAIL=tu-email@ejemplo.com
